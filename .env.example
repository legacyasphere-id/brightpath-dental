# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── AI (via OpenRouter — openai/... model IDs, OpenRouter API key) ──
OPENAI_API_KEY=sk-or-...
OPENAI_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENAI_CHAT_MODEL=openai/gpt-4o-mini

# ─── App Config ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CLINIC_NAME=BrightPath Dental
NEXT_PUBLIC_CLINIC_PHONE=+62-xxx-xxxx-xxxx
NEXT_PUBLIC_CLINIC_WHATSAPP=62xxxxxxxxxx

# ─── RAG Config ─────────────────────────────────────────────
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7

# ─── Admin ──────────────────────────────────────────────────
# Admin user is created via Supabase Auth dashboard
# Set these for seeding if needed
ADMIN_EMAIL=admin@brightpathdental.com
ADMIN_PASSWORD=change-me-in-production

# ─── Notifications ──────────────────────────────────────────
# Optional — fires a fire-and-forget webhook on new lead capture.
# Leave unset to skip notifications entirely.
MAKECOM_WEBHOOK_URL=
